#-------------------------------------------------------------------------------
# ENVIRONMENT VARIABLES
#-------------------------------------------------------------------------------
export PATH=$HOME/.dotfiles/base/bin:$PATH

#-------------------------------------------------------------------------------
# ALIASES
#-------------------------------------------------------------------------------
alias ps='ps kstart_time'
alias rm='rm -v'
alias cp='cp -v'
alias mv='mv -v'
alias ll='ls -al'
alias l='ls -al'

alias trimspace="sed 's/ \\+/ /g;s/^ \\| \$//g'"
alias rmvspace="tr -d ' '"

alias git_grep='git branch | tr -d \* | xargs git grep'

alias gd='ssh dev-godinus.ncl'

#-------------------------------------------------------------------------------
# Claude Shell Integration (Alt+E) - Bash version
#-------------------------------------------------------------------------------
_claude_shell() {
    if [[ -n "$READLINE_LINE" ]]; then
        local _old="$READLINE_LINE"
        local _sys="Convert the user's natural language input to a single shell command. Output ONLY the command,
nothing else."
        [[ -f ~/.claude-shell.md ]] && _sys="${_sys}\n\n$(cat ~/.claude-shell.md)"
        READLINE_LINE=$(claude -p --model haiku --tools "" --system-prompt "$_sys" "$_old" | sed '/^```/d')
        READLINE_POINT=${#READLINE_LINE}
    fi
}
bind -x '"\ee": _claude_shell'
